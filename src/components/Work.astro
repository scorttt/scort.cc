---
import Block from "./Block.astro";
import { Icon } from "astro-icon/components";
const { title, date, tags, links = [], image } = Astro.props;
---
<Block title={title} links={links} class="p-0">
    <div class="project-body">
        {image && (
            <div class="project-image-wrap ml-4">
                <a href={image} target="_blank" rel="noopener noreferrer">
                    <img src={image} alt={title} class="project-image" />
                </a>
            </div>
        )}
        <div class="project-date px-4 py-2">
            <Icon name="lucide:calendar" class="project-date-icon" />
            <span>{date}</span>
            <div class="ml-auto text-xs">{tags}</div>
        </div>
        <span class="project-desc px-4 pb-4">
            <span class="desc-short"><slot /></span>
            <span class="desc-full"><slot /></span>
        </span>
    </div>
</Block>

<script>
    // this entire script is written by ai i am not writing this shit myself this looks painful
    // im not even going to try to understand this and its probably really inefficient but i honestly dont care if it works
    document.addEventListener("astro:page-load", () => {
        setTimeout(() => {
            document.querySelectorAll(".project-desc").forEach((desc) => {
                const short = desc.querySelector(".desc-short") as HTMLElement;
                const full = desc.querySelector(".desc-full") as HTMLElement;
                if (!short || !full) return;
    
                short.style.display = "block";
                const renderedHeight = short.getBoundingClientRect().height;
                const lineHeight = parseInt(getComputedStyle(short).lineHeight) || 24;
                const maxHeight = lineHeight * 3;
                
                if (renderedHeight <= maxHeight + lineHeight) {
                    short.style.display = "";
                    return;
                }
    
                short.style.display = "";
                short.classList.add("truncated");
    
                const btn = document.createElement("button");
                btn.className = "read-more-btn";
                btn.textContent = "read more";
                desc.appendChild(btn);
    
                btn.addEventListener("click", () => syncRow(desc, true));
            });
        }, 0);
        document.addEventListener("click", (e) => {
            const btn = (e.target as HTMLElement).closest(".read-less-btn");
            if (btn)
                syncRow(btn.closest(".project-desc") as HTMLElement, false);
        });
    });

    function syncRow(desc: Element, expand: boolean) {
        const outerGrid = desc.closest(".block-wrapper")?.closest(".block-content");
        
        if (!outerGrid) 
            return;
            
        const thisTop = (desc.closest(".block-wrapper") as HTMLElement)?.offsetTop ?? 0;
        outerGrid.querySelectorAll(".block-wrapper").forEach((wrapper) => {
            
            if (Math.abs((wrapper as HTMLElement).offsetTop - thisTop) > 10) 
                return;
                
            wrapper.querySelectorAll(".project-desc").forEach((sib) => {
                if (!sib.querySelector(".read-more-btn") && !sib.querySelector(".read-less-btn")) 
                    return;
    
                const short = sib.querySelector(".desc-short") as HTMLElement;
                const full = sib.querySelector(".desc-full") as HTMLElement;
                const readMore = sib.querySelector(".read-more-btn") as HTMLElement;
                const el = sib as HTMLElement;
    
                if (expand) {
                    const fromHeight = el.scrollHeight;
                    el.style.height = `${fromHeight}px`;
    
                    short?.classList.add("hidden");
                    full?.classList.add("visible");
                    readMore?.remove();
    
                    if (!sib.querySelector(".read-less-btn")) {
                        const lessBtn = document.createElement("button");
                        lessBtn.className = "read-less-btn";
                        lessBtn.textContent = "read less";
                        sib.appendChild(lessBtn);
                    }
    
                    requestAnimationFrame(() => {
                        el.style.height = `${el.scrollHeight}px`;
                    });
                } else {
                    const fromHeight = el.getBoundingClientRect().height;
                
                    full?.classList.remove("visible");
                    sib.querySelector(".read-less-btn")?.remove();
                
                    if (!sib.querySelector(".read-more-btn")) {
                        const moreBtn = document.createElement("button");
                        moreBtn.className = "read-more-btn";
                        moreBtn.textContent = "read more";
                        sib.appendChild(moreBtn);
                        moreBtn.addEventListener("click", () => syncRow(sib, true));
                    }
                
                    short?.classList.remove("hidden");
                
                    // measure the truncated height off-screen
                    const clone = el.cloneNode(true) as HTMLElement;
                    clone.style.cssText = "position:fixed;visibility:hidden;pointer-events:none;width:" + el.getBoundingClientRect().width + "px";
                    document.body.appendChild(clone);
                    const toHeight = clone.getBoundingClientRect().height;
                    clone.remove();
                
                    el.style.height = `${fromHeight}px`;
                
                    requestAnimationFrame(() => requestAnimationFrame(() => {
                        el.style.height = `${toHeight}px`;
                    }));
                }
            });
        });
    }
</script>

<style>
    .project-date {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        color: var(--text-tertiary);
        font-weight: bold;
    }
    .project-date-icon {
        transform: translateY(-1px);
    }
    .project-body {
        padding-right: 0;
        padding-bottom: 0;
    }
    /* todo: better solution for image scaling since each image is definitely going to have a different aspect ratio */
    .project-image-wrap {
        position: relative;
        float: right;
        width: 200px;
        height: 143px;
        overflow: hidden;
    }
    .project-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: var(--radius-default);
    }
    .project-desc {
        display: block;
        font-size: 0.9rem;
        color: var(--text-secondary);
        position: relative;
        transition: height 0.5s cubic-bezier(0.5, 1, 0, 1);
        overflow: hidden;
    }
    .desc-short {
        display: block;
    }
    .desc-short.hidden {
        display: none;
    }
    .desc-short.truncated {
        max-height: calc(1.5em * 3);
        overflow: hidden;
        mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    }
    .desc-full {
        display: none;
        align-items: center;
    }
    .desc-full.visible {
        display: inline;
    }
</style>

<style is:global>
    .read-more-btn,
    .read-less-btn {
        color: var(--accent-blue);
        font-size: 0.9rem;
        cursor: pointer;
        font-family: inherit;
        font-weight: bold;
        display: block;
    }
    .read-more-btn:hover,
    .read-less-btn:hover {
        text-decoration: underline;
    }
</style>