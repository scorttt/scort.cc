---
import Block from "./Block.astro";
import { Icon } from "astro-icon/components";
const { title, date, tags, links = [], image } = Astro.props;
---
<Block title={title} links={links} class="p-0">
    <div class="project-body">
        {image && (
            <div class="project-image-wrap ml-4">
                <a href={image} target="_blank" rel="noopener noreferrer">
                    <img src={image} alt={title} class="project-image" />
                </a>
            </div>
        )}
        <div class="project-date px-4 py-2">
            <Icon name="lucide:calendar" class="project-date-icon" />
            <span>{date}</span>
            <div class="ml-auto text-xs">{tags}</div>
        </div>
        <span class="project-desc px-4 pb-4">
            <span class="desc-short"><slot /></span>
            <span class="desc-full"><slot /><button class="read-less-btn">read less</button></span>
        </span>
    </div>
</Block>

<script>
    // this entire script is written by ai i am not writing this shit myself this looks painful
    // im not even going to try to understand this and its probably really inefficient but i honestly dont care if it works
    document.addEventListener("astro:page-load", () => {
        document.querySelectorAll(".project-desc").forEach((desc) => {
            const short = desc.querySelector(".desc-short") as HTMLElement;
            const full = desc.querySelector(".desc-full") as HTMLElement;
            if (!short || !full) return;

            const originalHTML = short.innerHTML;

            // force block for measurement
            short.style.display = "block";
            const lineHeight = parseInt(getComputedStyle(short).lineHeight);
            const maxHeight = lineHeight * 4;

            if (short.scrollHeight <= maxHeight) { 
                short.style.display = ""; 
                return; 
            }   

            // binary search for truncation point
            const text = short.textContent ?? "";
            let lo = 0, hi = text.length;
            while (lo < hi - 1) {
                const mid = Math.floor((lo + hi) / 2);
                short.textContent = text.slice(0, mid) + " … read more";
                if (short.scrollHeight <= maxHeight) 
                    lo = mid; 
                else 
                    hi = mid;
            }

            const applyTruncation = (limit: number) => {
                const wordTrimmed = (text.slice(0, limit).trimEnd()).replace(/[,;:!?.]+$/, "");
                short.innerHTML = originalHTML;
                truncateTextNodes(short, wordTrimmed.length);
                const btn = document.createElement("button");
                btn.className = "read-more-btn";
                btn.textContent = "read more";
                (findLastBlock(short) ?? short).append("… ", btn);
                return btn;
            };

            let readMoreBtn = applyTruncation(lo);
            short.style.display = "block"

            while (short.scrollHeight > maxHeight && lo > 0) {
                lo--;
                readMoreBtn = applyTruncation(lo);
            }

            short.style.display = "";

            readMoreBtn.addEventListener("click", () => syncRow(desc, true));
        });

        document.addEventListener("click", (e) => {
            const btn = (e.target as HTMLElement).closest(".read-less-btn");
            if (btn)
                syncRow(btn.closest(".project-desc") as HTMLElement, false);
        });
    });

    function syncRow(desc: Element, expand: boolean) {
        const outerGrid = desc.closest(".block-wrapper")?.closest(".block-content");
        if (!outerGrid) return;
        const thisTop = (desc.closest(".block-wrapper") as HTMLElement)?.offsetTop ?? 0;
        outerGrid.querySelectorAll(".block-wrapper").forEach((wrapper) => {
            if (Math.abs((wrapper as HTMLElement).offsetTop - thisTop) > 10) return;
            wrapper.querySelectorAll(".project-desc").forEach((sib) => {
                if (!sib.querySelector(".read-more-btn")) return;
                sib.querySelector(".desc-short")?.classList.toggle("hidden", expand);
                sib.querySelector(".desc-full")?.classList.toggle("visible", expand);
            });
        });
    }

    function truncateTextNodes(node: Node, limit: number): number {
        if (node.nodeType === Node.TEXT_NODE) {
            const text = node.textContent ?? "";
            if (limit <= 0) {
                node.textContent = "";
                return 0;
            }
            if (text.length <= limit)
                return limit - text.length;
            node.textContent = text.slice(0, limit).trimEnd();
            return 0;
        }
        if (node.nodeType === Node.ELEMENT_NODE) {
            const children = Array.from(node.childNodes);
            for (const child of children) {
                if (limit <= 0)
                    (node as Element).removeChild(child);
                else
                    limit = truncateTextNodes(child, limit);
            }
        }
        return limit;
    }
    
    function findLastBlock(node: HTMLElement): HTMLElement | null {
        const blockTags = new Set(["LI", "P", "DIV", "SPAN"]);
        for (const child of Array.from(node.childNodes).reverse()) {
            if (child.nodeType === Node.ELEMENT_NODE) {
                const el = child as HTMLElement;
                if (blockTags.has(el.tagName) && el.textContent?.trim())
                    return findLastBlock(el) ?? el;
            }
        }
        return null;
    }
</script>

<style>
    .project-date {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        color: var(--text-tertiary);
        font-weight: bold;
    }
    .project-date-icon {
        transform: translateY(-1px);
    }
    .project-body {
        padding-right: 0;
        padding-bottom: 0;
    }
    .project-image-wrap {
        position: relative;
        float: right;
        width: 200px;
        height: 130px;
        overflow: hidden;
    }
    .project-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: var(--radius-default);
    }
    .project-desc {
        display: block;
        font-size: 0.9rem;
        color: var(--text-secondary);
    }
    .desc-full {
        display: none;
        align-items: center;
    }
    .desc-full.visible {
        display: inline;
    }
</style>

<style is:global>
    .read-more-btn,
    .read-less-btn {
        color: var(--accent-blue);
        font-size: 0.9rem;
        cursor: pointer;
        font-family: inherit;
        font-weight: bold;
        display: inline;
    }
    .read-more-btn:hover,
    .read-less-btn:hover {
        text-decoration: underline;
    }
</style>