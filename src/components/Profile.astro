---
import { Icon } from 'astro-icon/components';
---

<div class="flex flex-row gap-4 md:gap-8 profile-container">
    <div class="profile-pfp profile-pfp-placeholder" id="profile-avatar"></div>
    <div class="flex flex-col profile-text">
        <span class="text-xl md:text-2xl font-bold" id="profile-name">scort</span>
        <div class="text-xs md:text-sm" id="status-container">
            <span class="status-indicator" id="status-indicator" data-status="offline"></span>
            <Icon name="lucide:gamepad-2" id="status-indicator-game" class="status-indicator-game" />
            <span id="status-text">offline</span>
            <span id="game-elapsed" class="game-elapsed" style="display:none"></span>
        </div>
    </div>
</div>

<script>
    document.addEventListener("astro:page-load", () => 
    {
        const UID = "66056020786425856";
        const avatarElement = document.getElementById('profile-avatar');
        const nameElement = document.getElementById('profile-name');
        const statusIndicator = document.getElementById('status-indicator');
        const statusIndicatorGame = document.getElementById('status-indicator-game');
        const statusText = document.getElementById('status-text');
        
        const gameElapsed = document.getElementById('game-elapsed') as HTMLElement;
        const maxGameTextLength = 30;
    
        let gameInterval: ReturnType<typeof setInterval> | null = null;
        let currentGameStart: number | null = null;
    
        async function fetchLanyardData() 
        {
            try 
            {
                const response = await fetch(`https://api.lanyard.rest/v1/users/${UID}`);
                if (response.ok) 
                {
                    const lanyard = (await response.json()).data;
    
                    if (lanyard.discord_user) 
                    {
                        const { id, avatar, global_name } = lanyard.discord_user;
                        const avatarUrl = `https://cdn.discordapp.com/avatars/${id}/${avatar}.png?size=256`;
                        
                        if (avatarElement) 
                        {
                            avatarElement.style.backgroundImage = `url(${avatarUrl})`;
                            avatarElement.classList.remove('profile-pfp-placeholder');
                        }
                        
                        if (nameElement) 
                            nameElement.textContent = global_name || 'scort';
                    }
    
                    const game = lanyard.activities.find((a: any) => a.type === 0);
    
                    if (statusIndicator && statusIndicatorGame && statusText) 
                    {
                        statusIndicator.setAttribute('data-status', lanyard.discord_status);
                        statusIndicator.style.display = game ? 'none' : 'inline-block';
                        statusIndicatorGame.style.display = game ? 'inline-block' : 'none';
                        statusIndicatorGame.setAttribute('data-status', lanyard.discord_status);
                        
                        const text = game ? `playing ${game.name}` : lanyard.discord_status;
                        statusText.textContent = text.length > maxGameTextLength ? text.slice(0, maxGameTextLength) + "…" : text;
                        statusText.title = text.length > maxGameTextLength ? (game ? game.name : lanyard.discord_status) : "";
                    }

                    if (game && game.timestamps && game.timestamps.start)
                    {
                        gameElapsed.style.display = 'block';

                        if (game.timestamps.start !== currentGameStart)
                        {
                            currentGameStart = game.timestamps.start;
                            
                            if (gameInterval) 
                                clearInterval(gameInterval);

                            const tick = () => 
                            {
                                const elapsed = Math.floor((Date.now() - game.timestamps.start) / 1000);
                                const hour = Math.floor(elapsed / 3600);
                                const minute = Math.floor((elapsed % 3600) / 60);
                                const second = elapsed % 60;
                                gameElapsed.textContent = hour > 0
                                    ? `${hour}:${String(minute).padStart(2, "0")}:${String(second).padStart(2, "0")}`
                                    : `${minute}:${String(second).padStart(2, "0")}`;
                            };
                            tick();
                            gameInterval = setInterval(tick, 1000);
                        }
                    }
                    else
                    {
                        gameElapsed.style.display = 'none';
                        if (gameInterval) 
                        { 
                            clearInterval(gameInterval);
                            gameInterval = null;
                        }
                        currentGameStart = null;
                    }
                }
                else 
                {
                    console.error('Lanyard API error:', response.status, response.statusText);
                }
            } 
            catch (error) 
            {
                console.error('Failed to fetch Lanyard data:', error);
            }
        }
    
        fetchLanyardData();
        setInterval(fetchLanyardData, 10000);
    })
</script>

<style>
    :root {
        --pfp-size: 64px;
    }
    @media (min-width: theme('screens.md')) {
        :root {
            --pfp-size: 96px;
        }
    }

    .profile-container {
        width: 100%;
        padding-right: 1em;
    }

    .profile-pfp {
        width: var(--pfp-size);
        height: var(--pfp-size);
        border-radius: 100px;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }
    
    .profile-pfp-placeholder {
        background-color: var(--bg-secondary);
    }
    
    .profile-text {
        justify-content: center;
    }

    #status-text {
        text-transform: lowercase;
    }

    .status-indicator {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-right: 4px;
        transform: translateY(1px);
    }

    .status-indicator-game {
        display: none;
        width: 16px;
        height: 16px;
        margin-right: 2px;
        vertical-align: middle;
    }

    .game-elapsed {
        font-size: 0.7rem;
        color: var(--text-tertiary);
        font-family: var(--font-code);
    }

    [data-status="online"] { 
        --status-color: rgba(69, 163, 102, 1);
        --status-glow: rgba(69, 163, 102, 0.7);
    }
    [data-status="idle"] { 
        --status-color: rgba(255, 192, 78, 1);
        --status-glow: rgba(255, 192, 78, 0.7);
    }
    [data-status="dnd"] { 
        --status-color: rgba(218, 62, 68, 1);
        --status-glow: rgba(218, 62, 68, 0.7);
    }
    [data-status="offline"] { 
        --status-color: rgba(133, 133, 133, 1);
        --status-glow: rgba(133, 133, 133, 0.7);
    }

    .status-indicator {
        background-color: var(--status-color);
        box-shadow: 0 0 8px var(--status-glow);
    }

    .status-indicator-game {
        color: var(--status-color);
        filter: drop-shadow(0 0 4px var(--status-glow));
    }
</style>
